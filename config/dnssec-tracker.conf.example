; dnssec-tracker configuration
;
; Style mirrors iodyn-dnssec.conf so the two tools feel familiar side by side.

[paths]
; Root of BIND's key-directory tree. By default the tracker walks
; `key_dir` itself plus one level of immediate subdirectories,
; which covers the two common BIND layouts:
;   * flat:        /mnt/bind/keys/K<zone>.+<algo>+<tag>.{key,state}
;   * per-zone:    /mnt/bind/keys/<zonename>/K...key
; Hidden directories (anything starting with ".") are skipped so
; backup/holding trees like keys/.bak/<zone>/ don't leak stale
; keys into the live view. Flip `key_dir_recursive` below if your
; tree genuinely nests deeper.
key_dir      = /mnt/bind/keys
; key_dir_recursive = no    ; default — root + one level down only
; key_dir_recursive = yes   ; full Path.rglob walk (still skips
;                           ; hidden "." subdirectories)

; Host syslog file (mount read-only). The syslog collector tails it for
; lines from iodyn-dnssec and named.
syslog       = /mnt/host/var/log/syslog

; BIND's configured log file (optional). Leave empty to disable the
; named_log collector.
named_log    = /mnt/bind/log/named.log

; SQLite database path. The parent directory must be writable by the
; `tracker` user inside the container.
db           = /var/lib/dnssec-tracker/events.db

[dns]
; Resolver used when querying the zone directly. Usually the BIND you
; are observing.
local_resolver  = 127.0.0.1:53

; How often (seconds) to query the zone for DNSKEY/RRSIG/CDS/CDNSKEY/SOA.
query_interval  = 60

; How often (seconds) to query the parent zone for DS.
parent_interval = 300

; Optional timeout (seconds) for each DNS query.
query_timeout   = 5

[collectors]
; Toggle each collector. "on" or "off".
state_file  = on
key_file    = on
syslog      = on
named_log   = on
dns_probe   = on
; rndc_status captures BIND's own view of each key's state
; (goal / dnskey / ds / zone rrsig / key rrsig = hidden | rumoured |
; omnipresent | unretentive) via `rndc dnssec -status <zone>`. This is
; the cleanest window into what BIND actually thinks is happening and
; is on by default.
rndc_status = on

[rndc]
; Used by the rndc_status collector. Runs `rndc dnssec -status <zone>`
; every `interval` seconds for each discovered zone.
key_file = /mnt/bind/rndc.key
server   = 127.0.0.1:953
rndc_bin = /usr/sbin/rndc
interval = 300

[web]
; FastAPI bind address. In production bind to localhost and expose via
; SSH tunnel or a reverse proxy — the UI has no authentication.
bind = 0.0.0.0:8080

; Page size for the event log.
events_per_page = 100
